{
  "bun_server_bench_id": "event-sourcing.idempotent-projection.v1",
  "task_version": "1.0.0",
  "spec_version": "0.1.0",
  "title": "Idempotent event-sourced read-model projection",
  "category": "databases",
  "difficulty": {
    "level": 5,
    "rationale": "Requires log-derived state, idempotent replay, gap buffering, version conflicts, poison quarantine, and rebuild determinism matching incremental apply.",
    "expected_code_size": {
      "min_lines": 120,
      "max_lines": 400
    },
    "expected_concepts": [
      "event append log",
      "versioned projection",
      "idempotent replay",
      "gap buffering",
      "deterministic rebuild"
    ]
  },
  "tags": [
    "databases",
    "bun",
    "event-sourcing",
    "projection",
    "idempotency"
  ],
  "scoring": {
    "max_score": 100,
    "gates": [
      {
        "name": "installs",
        "requirement": "install exits with status 0",
        "on_fail": "zero"
      },
      {
        "name": "starts",
        "requirement": "readiness check passes",
        "on_fail": "zero"
      },
      {
        "name": "security_baseline",
        "requirement": "no hidden test access or network egress",
        "on_fail": "zero"
      }
    ],
    "weights": {
      "correctness": 0.6,
      "edge_cases": 0.25,
      "performance": 0.05,
      "security": 0.05,
      "maintainability": 0.05
    },
    "performance": {
      "metric": "p95_latency_ms",
      "budget": 80,
      "floor": 10
    },
    "dependency_budget": {
      "max_runtime_dependencies": 0,
      "penalty_per_extra_dependency": 1
    }
  },
  "success_criteria": {
    "must": [
      "POST /events appends versioned events and updates GET /projections/:id.",
      "Duplicate identical events return 200 without double apply.",
      "POST /projections/:id/rebuild reproduces incremental state."
    ],
    "must_not": [
      "Apply events past a version gap.",
      "Apply quarantined unknown event types to the projection.",
      "Accept conflicting payloads at the same version."
    ],
    "edge_cases": [
      "Out-of-order events buffer until the missing version arrives.",
      "Oversized version gaps return 409 gap_not_allowed.",
      "Rebuild state equals incremental state."
    ]
  },
  "environment_network": "disabled",
  "reward_model": {
    "description": "Harbor reward.txt is computed by the bun-server-bench gate model in tests/test.sh.",
    "values": {
      "public_and_hidden_pass": 1,
      "public_pass_hidden_fail": 0.25,
      "public_fail": 0
    },
    "maps_to_bun_server_bench_score": {
      "1.0": 100,
      "0.25": 25,
      "0.0": 0
    }
  }
}
