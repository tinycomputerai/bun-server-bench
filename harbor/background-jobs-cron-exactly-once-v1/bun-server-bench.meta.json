{
  "bun_server_bench_id": "background-jobs.cron-exactly-once.v1",
  "task_version": "1.0.0",
  "spec_version": "0.1.0",
  "title": "Exactly-once cron scheduler per slot",
  "category": "background-jobs",
  "difficulty": {
    "level": 5,
    "rationale": "Each (job, scheduled_time) executes at most once.",
    "expected_code_size": {
      "min_lines": 120,
      "max_lines": 400
    },
    "expected_concepts": [
      "slot-scheduling",
      "exactly-once",
      "catch-up-policy",
      "overlap-skip",
      "restart-recovery"
    ]
  },
  "tags": [
    "background-jobs",
    "bun",
    "cron",
    "scheduling",
    "exactly-once"
  ],
  "scoring": {
    "max_score": 100,
    "gates": [
      {
        "name": "installs",
        "requirement": "install exits with status 0",
        "on_fail": "zero"
      },
      {
        "name": "starts",
        "requirement": "readiness check passes",
        "on_fail": "zero"
      },
      {
        "name": "security_baseline",
        "requirement": "no hidden test access or network egress",
        "on_fail": "zero"
      }
    ],
    "weights": {
      "correctness": 0.6,
      "edge_cases": 0.25,
      "performance": 0.05,
      "security": 0.05,
      "maintainability": 0.05
    },
    "performance": {
      "metric": "p95_latency_ms",
      "budget": 200,
      "floor": 10
    },
    "dependency_budget": {
      "max_runtime_dependencies": 0,
      "penalty_per_extra_dependency": 1
    }
  },
  "success_criteria": {
    "must": [
      "Each (job, scheduled_time) executes at most once.",
      "Missed tick policy catch_up or skip is honored.",
      "Overlapping long runs skip duplicate slot starts."
    ],
    "must_not": [
      "Expose stack traces in HTTP responses."
    ],
    "edge_cases": [
      "Hidden tests cover concurrency, failure injection, and security edge cases."
    ]
  },
  "environment_network": "disabled",
  "reward_model": {
    "description": "Harbor reward.txt is computed by the bun-server-bench gate model in tests/test.sh.",
    "values": {
      "public_and_hidden_pass": 1,
      "public_pass_hidden_fail": 0.25,
      "public_fail": 0
    },
    "maps_to_bun_server_bench_score": {
      "1.0": 100,
      "0.25": 25,
      "0.0": 0
    }
  }
